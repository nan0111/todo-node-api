{
  "name": "todo-api266",
  "version": "1.0.0",
  "description": "todo-api Node.js",
  "main": "dist/server.js",
  "scripts": {
    "start": "NODE_ENV=production node dist/src/server.js",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "NODE_ENV=development dotenv -e .env jest --forceExit",
    "test:doc": "docker compose -f compose.yml -f compose.debug.yml exec -it app npm test",
    "test:docw": "docker compose -f compose.yml -f compose.debug.yml exec -it app npx jest --watchAll"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nan0111/todo-api266.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nan0111/todo-api266/issues"
  },
  "homepage": "https://github.com/nan0111/todo-api266#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "glob": "^11.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "glob": "^11.1.0"
  }
}
